{
  "name": "openvpn-manager",
  "version": "1.0.0",
  "description": "OpenVPN3 Manager for Linux",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build": "npm run build:main && npm run build:renderer",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "webpack --config webpack.renderer.config.js --mode development --watch",
    "electron": "electron dist/main/main.js",
    "start": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"wait-on dist/main/main.js dist/renderer/index.html && sleep 2 && npm run electron\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:deb": "npm run build && electron-builder --linux deb",
    "dist:appimage": "npm run build && electron-builder --linux AppImage"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "concurrently": "^8.0.0",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "html-webpack-plugin": "^5.5.4",
    "mini-css-extract-plugin": "^2.7.6",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.0",
    "wait-on": "^7.0.1",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.openvpn.manager",
    "productName": "OpenVPN Manager",
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Network",
      "icon": "assets/icon.png"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    }
  }
}
