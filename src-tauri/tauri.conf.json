{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenVPN Manager",
  "version": "1.0.0",
  "identifier": "com.openvpn.manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenVPN Manager",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.svg"],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libssl3"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "category": "Network",
    "shortDescription": "OpenVPN3 Manager for Linux"
  }
}
