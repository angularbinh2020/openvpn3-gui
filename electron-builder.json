{
  "appId": "com.openvpn.manager",
  "productName": "OpenVPN Manager",
  "copyright": "Copyright © 2024",
  "directories": {
    "buildResources": "assets",
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "assets/**/*",
    "!dist/**/*.map"
  ],
  "linux": {
    "target": [
      {
        "target": "deb",
        "arch": ["x64"]
      },
      {
        "target": "AppImage",
        "arch": ["x64"]
      }
    ],
    "category": "Network",
    "icon": "assets/icon.png",
    "description": "OpenVPN3 Manager for Linux",
    "desktop": {
      "Name": "OpenVPN Manager",
      "Comment": "Manage OpenVPN3 connections",
      "Categories": "Network;VPN;"
    }
  },
  "deb": {
    "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils", "libatspi2.0-0", "libsecret-1-0"]
  },
  "publish": null
}
